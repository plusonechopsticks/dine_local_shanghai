# ========================================
# REQUIRED FOR PRODUCTION
# ========================================

# Database (MySQL)
DATABASE_URL=mysql://user:password@host/database

# JWT Secret for session cookies (generate a random string, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# ========================================
# OPTIONAL - OAuth (for login feature)
# ========================================
OAUTH_SERVER_URL=https://your-oauth-server.com
VITE_APP_ID=your-app-id
OWNER_OPEN_ID=your-owner-id

# ========================================
# OPTIONAL - Manus Forge integrations
# (LLM, image generation, notifications, maps, storage)
# ========================================
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ========================================
# OPTIONAL - Client-side env vars
# (for analytics, Google Maps API, etc.)
# ========================================
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-forge-api-key

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id
