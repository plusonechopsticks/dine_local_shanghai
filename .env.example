# ============================================================
# Railway Environment Variables
# Copy these into your Railway project's "Variables" panel.
# ============================================================

# --- Database (auto-provided by Railway MySQL plugin) ------
DATABASE_URL=mysql://user:password@host:3306/railway

# --- App / Auth --------------------------------------------
VITE_APP_ID=your_wechat_app_id
VITE_WEBSITE_URL=https://plus1chopsticks.com
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
OWNER_OPEN_ID=your_wechat_open_id
OAUTH_SERVER_URL=https://your-oauth-server.com

# --- Email (Resend) ----------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@plus1chopsticks.com

# --- Stripe ------------------------------------------------
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# --- Cloudinary (image storage) ----------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Manus Forge AI (leave blank if migrating away) --------
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key
