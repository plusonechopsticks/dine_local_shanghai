                {/* Card Content */}
                <div className="p-6">
                  <h3 className="text-xl font-bold text-gray-900 mb-2 group-hover:text-red-600 transition-colors duration-200">
                    {card.name}
                  </h3>
                  <p className="text-gray-600 mb-4">{card.cuisine}</p>
                  <p className="text-sm text-gray-500 mb-4">
                    All hosts are vetted for language capability, food hygiene, and
                    home environment.
                  </p>
                  <Button className="w-full bg-red-600 hover:bg-red-700 text-white transition-all duration-200 hover:shadow-lg">
                    View Details
                  </Button>
                </div>
              </div>
            ))}
          </div>

          <div className="text-center mt-12">
            <Button
              variant="outline"
              className="border-gray-300 text-gray-900 hover:bg-gray-100"
            >
              Browse All Hosts
            </Button>
          </div>
        </div>
      </section>

      {/* Section 4: How it Works */}
      <section className="py-16 bg-white">
        <div className="container mx-auto px-4">
          <h2 className="text-3xl font-bold text-center text-gray-900 mb-12">
            How it Works — The Easy-Peasy Guide
          </h2>

          <div className="grid grid-cols-1 md:grid-cols-4 gap-8">
            {[
              {
                step: 1,
                icon: "🔍",
                title: "Browse",
                description:
                  "Pick your favorite host and menu. Check for language capability and accessibility.",
              },
              {
                step: 2,
                icon: "📅",
                title: "Book",
                description:
                  "Request your date and pay for the confirmed booking; our team handles the rest.",
              },
              {
                step: 3,
                icon: "📧",
                title: "Prepare",
                description:
                  "Receive location details via email/WeChat. We'll share a Dining Cheat Sheet.",
              },
              {
                step: 4,
                icon: "🍽️",
                title: "Eat",
                description:
                  "Show up, share a pair of chopsticks, and make a new friend.",
              },
            ].map((item, idx) => (
              <div key={item.step} className="relative">
                {/* Step Number Circle */}
                <div className="flex justify-center mb-6">
                  <div className="w-12 h-12 rounded-full bg-red-600 text-white flex items-center justify-center font-bold text-lg shadow-lg">
                    {item.step}
                  </div>
                </div>
                
                <div className="text-center">
                  <div className="text-5xl mb-4">{item.icon}</div>
                  <h3 className="text-xl font-bold text-gray-900 mb-2">
                    {item.title}
                  </h3>
                  <p className="text-gray-600 text-sm">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Section 5: Founder's Story */}
      <section className="py-16 bg-white">
        <div className="container mx-auto px-4">
          <h2 className="text-3xl font-bold text-center text-gray-900 mb-12">
            About Us: A Bridge Between China and the West
          </h2>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            {/* Left: Founder Photo */}
            <div>
              <img
                src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=400&fit=crop"
                alt="Steven, Founder"
                className="w-full rounded-lg shadow-xl mb-6 hover:shadow-2xl transition-shadow duration-300"
              />
              <div className="grid grid-cols-2 gap-4">
                {[
                  {
                    img: "https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=200&h=200&fit=crop",
                    caption: "Dining with friends in Nairobi, 2018",
                  },
                  {
                    img: "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200&h=200&fit=crop",
                    caption: "Sharing stories in Copenhagen",
                  },
                  {
                    img: "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200&h=200&fit=crop",
                    caption: "Shanghai dining experiences",
                  },
                  {
                    img: "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200&h=200&fit=crop",
                    caption: "Home cooking moments",
                  },
                ].map((photo, idx) => (
                  <div key={idx} className="relative group cursor-pointer">
                    <img
                      src={photo.img}
                      alt={photo.caption}
                      className="w-full h-40 object-cover rounded-lg shadow-md group-hover:shadow-lg transition-all duration-300 group-hover:scale-105"
                    />
                    <div className="absolute inset-0 bg-black/0 group-hover:bg-black/50 transition-all duration-300 rounded-lg flex items-center justify-center">
                      <p className="text-white text-xs text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 p-2">
                        {photo.caption}
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            {/* Right: Story Text */}
            <div className="space-y-6">
              <div className="border-l-4 border-red-600 pl-6">
                <h3 className="text-2xl font-bold text-gray-900 mb-4">
                  Hi, I'm Steven
                </h3>
                <p className="text-gray-700 leading-relaxed">
                  Founder and CEO of +1 Chopsticks. Born and raised in Hong Kong, I have
                  studied and worked in the US, married my beautiful wife from Tianjin,
                  and lived in Chicago, Copenhagen, Nairobi, Beijing, and Shanghai.
                </p>
              </div>

              <div className="border-l-4 border-red-600 pl-6">
                <h4 className="font-bold text-gray-900 mb-2 text-lg">My Passion</h4>
                <p className="text-gray-700 leading-relaxed">
                  I'm the author of the "China vs the West" series as I'm deeply
                  passionate about bridging the gap, debunking myths, and showing the
                  authentic China to everyone.
                </p>
              </div>

              <div className="border-l-4 border-red-600 pl-6">
                <h4 className="font-bold text-gray-900 mb-2 text-lg">My Journey</h4>
                <p className="text-gray-700 leading-relaxed">
